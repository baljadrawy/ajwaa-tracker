# ============================================================
#  Ajwaa Tracker — متغيرات البيئة
#  انسخ هذا الملف إلى .env وعدّل القيم قبل التشغيل
#  cp .env.example .env
# ============================================================

# ── قاعدة البيانات ───────────────────────────────────────────
DB_NAME=ajwaa_db
DB_USER=ajwaa
# ⚠️ غيّر هذه القيمة في الإنتاج
DB_PASSWORD=ajwaa_pass_prod_2026

# ── JWT ──────────────────────────────────────────────────────
# ⚠️ استخدم قيمة عشوائية طويلة (32+ حرف) في الإنتاج
# مثال لتوليد قيمة عشوائية: openssl rand -hex 32
JWT_SECRET=ajwaa-jwt-change-this-secret-key-2026

# ── بيئة التشغيل ─────────────────────────────────────────────
# القيم المقبولة: development | production
NODE_ENV=production

# ── منفذ الـ Backend ─────────────────────────────────────────
PORT=4000

# ── PostgreSQL — إعدادات إضافية (اختياري) ────────────────────
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
